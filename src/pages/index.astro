---
import Layout from '../layouts/Layout.astro';
import WeeklyChart from '../components/WeeklyChart.astro';
import WeightChart from '../components/WeightChart.astro';
import tracking from '../content/tracking.json';
import metrics from '../content/metrics.json';
import { sortByDateDesc } from '../utils/weeklyBalance';

const dias = sortByDateDesc(tracking);
const metricas = sortByDateDesc(metrics);
const ultimaMetrica = metricas[0];
const ultimaCintura = metricas.find(m => m.cintura != null);

const ALTURA = 1.85;
const pesoActual = ultimaMetrica?.peso ?? null;
const cinturaActual = ultimaCintura?.cintura ?? null;
const imc = pesoActual ? (pesoActual / (ALTURA * ALTURA)).toFixed(1) : '—';

function kcalColor(kcal: number) {
  if (kcal < 1700) return 'var(--accent2)';
  if (kcal <= 2100) return 'var(--green)';
  return 'var(--yellow)';
}

// Progresión de fuerza
function parseTotal(text: string, keyword: string): number | null {
  const re = new RegExp(keyword.replace('-', '\\-') + '[^=]+=([0-9]+)');
  const m = text.match(re);
  return m ? parseInt(m[1]) : null;
}

const trackingSorted = [...tracking].sort((a, b) => a.fecha.localeCompare(b.fecha));

const progTiron = trackingSorted
  .filter(e => (e.entreno ?? '').includes('pull-ups'))
  .slice(-5)
  .map(e => ({
    fecha: e.fecha,
    pullups: parseTotal(e.entreno ?? '', 'pull-ups'),
    chinups: parseTotal(e.entreno ?? '', 'chin-ups'),
  }));

const progEmpuje = trackingSorted
  .filter(e => (e.entreno ?? '').includes('pushups'))
  .slice(-5)
  .map(e => ({
    fecha: e.fecha,
    pushups: parseTotal(e.entreno ?? '', 'pushups'),
  }));

// Diario: 7 recientes + resto
const diasRecientes = dias.slice(0, 7);
const diasAnteriores = dias.slice(7);
---
<Layout title="Papiletics — Plan de recomposición corporal">

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  PERFIL                      ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="perfil">
    <p class="section-title">Perfil</p>

    <div class="stats">
      <div class="stat">
        <div class="val">{pesoActual != null ? pesoActual.toLocaleString('es-ES') + ' kg' : '—'}</div>
        <div class="lbl">Peso actual</div>
      </div>
      <div class="stat">
        <div class="val">80 kg</div>
        <div class="lbl">Objetivo</div>
      </div>
      <div class="stat">
        <div class="val">{cinturaActual != null ? cinturaActual.toLocaleString('es-ES') + ' cm' : '—'}</div>
        <div class="lbl">Cintura actual</div>
      </div>
      <div class="stat">
        <div class="val">{imc}</div>
        <div class="lbl">IMC (kg/m²)</div>
      </div>
    </div>

    <div class="card">
      <h4>Cálculos base</h4>
      <div class="table-wrap">
        <table>
          <tbody>
            <tr><td>Edad / Altura</td><td><strong>45 años · 1.85 m</strong></td></tr>
            <tr><td>BMR estimado (Mifflin-St Jeor)</td><td><strong>~1.796 kcal</strong></td></tr>
            <tr><td>TDEE (actividad ligera-moderada)</td><td><strong>~2.400 kcal</strong></td></tr>
            <tr><td>Objetivo calórico diario</td><td><strong>~2.000 kcal</strong></td></tr>
            <tr><td>Déficit real estimado</td><td><strong>~400 kcal/día</strong></td></tr>
            <tr><td>Proteína diaria objetivo</td><td><strong>160–175 g (2 g/kg)</strong></td></tr>
            <tr><td>Tiempo estimado al objetivo</td><td><strong>20–28 semanas</strong></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="callout">
      <strong>Pérdida esperada:</strong> 0.5–1 kg de grasa/mes si el déficit es consistente. La cintura es mejor indicador que el peso a corto plazo.
    </div>

  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  NUTRICIÓN                   ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="nutricion">
    <p class="section-title">Nutrición</p>

    <!-- Presupuesto calórico -->
    <div class="card" style="margin-bottom: 16px;">
      <h3>Presupuesto calórico diario</h3>
      <div class="budget-item">
        <span class="budget-label">Comida principal</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 37%"></div></div>
        <span class="budget-kcal">750 kcal</span>
      </div>
      <div class="budget-item">
        <span class="budget-label">Cena</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 30%; background: var(--green)"></div></div>
        <span class="budget-kcal">600 kcal</span>
      </div>
      <div class="budget-item">
        <span class="budget-label">Snack + merienda</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 33%; background: var(--yellow)"></div></div>
        <span class="budget-kcal">650 kcal</span>
      </div>
      <div style="border-top: 1px solid var(--border); margin-top: 12px; padding-top: 10px; display: flex; justify-content: space-between; align-items: center;">
        <span style="font-size: 13px; color: var(--muted);">TOTAL DIARIO</span>
        <span style="font-size: 20px; font-weight: 700; color: var(--accent);">~2.000 kcal</span>
      </div>
    </div>

    <!-- Tupper fijo -->
    <details class="recipe-group" open>
      <summary>🍱 Comida fija — Tupper (L–V) <span class="recipe-meta">~600 kcal · ~49 g prot</span></summary>
      <div class="recipe-group-body">
        <div class="meal-card" style="margin-bottom:0">
          <div class="meal-body">
            <h4>Pollo con pisto y quinoa</h4>
            <ul>
              <li><span>Pechuga de pollo (crudo)</span><span>200 g · 220 kcal · 42 g</span></li>
              <li><span>Cebolla + pimiento + calabacín</span><span>150 g · 60 kcal</span></li>
              <li><span>Tomate triturado</span><span>150 ml · 40 kcal</span></li>
              <li><span>Quinoa en seco (o arroz blanco)</span><span>65 g · 235 kcal · 7 g</span></li>
              <li><span>Aceite de oliva (cucharita de café)</span><span>5 ml · 45 kcal</span></li>
            </ul>
            <div class="callout" style="margin-top: 12px; margin-bottom: 0;">
              <strong>Logística:</strong> Prepara 5 raciones el domingo. Refrigera 3, congela 2. En 40 minutos tienes la semana resuelta. Los martes cuando preparas el caldo de tus hijas es buen momento.
            </div>
          </div>
        </div>
      </div>
    </details>

    <!-- Cenas -->
    <details class="recipe-group">
      <summary>🌙 Cenas rotativas — elige una</summary>
      <div class="recipe-group-body">

    <div class="meal-card">
      <div class="meal-header">
        <h3>🥗 A — Lechuga + atún + huevo + salsa fit</h3>
        <span class="meal-meta">~490 kcal · 50 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Lechuga iceberg</span><span>150–160 g</span></li>
          <li><span>Atún (girasol o natural)</span><span>100 g</span></li>
          <li><span>Huevo duro</span><span>1 ud</span></li>
          <li><span>Pan de molde</span><span>65–70 g (2 rebanadas)</span></li>
          <li><span>Salsa: yogur griego 100 g + mostaza 20 g + mayo ligera 15 g + limón + ajo + sal</span><span>~120 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          La cena más repetida y más completa. Pan real, sin trucos raros. Si el atún es en girasol, escurre bien.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🫓 B — Pizza tortilla de trigo integral (verano)</h3>
        <span class="meal-meta">~500–550 kcal · 38–42 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Tortilla de trigo integral (~45 g)</span><span>~145 kcal</span></li>
          <li><span>Tomate triturado natural</span><span>80–100 g · ~30 kcal</span></li>
          <li><span>Mozzarella</span><span>80 g · ~220 kcal · 16 g prot</span></li>
          <li><span>Pollo en tiras o atún</span><span>100 g · ~110–90 kcal · ~22 g prot</span></li>
          <li><span>Pimiento + cebolla + champiñones (salteados)</span><span>libres · ~30 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Sartén a fuego medio tapada — efecto horno. Mozzarella máx. 80 g. Sin bases de coliflor ni garbanzos — la tortilla integral ya es la solución correcta.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🐟 C — Salmón + brócoli</h3>
        <span class="meal-meta">~310 kcal · 32 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Salmón a la plancha</span><span>150 g</span></li>
          <li><span>Brócoli al vapor / plancha</span><span>200 g</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Solo si sobra salmón de la comida — no planificar como cena fija.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🫘 D — Ensalada de legumbres</h3>
        <span class="meal-meta">~460 kcal · 32 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Garbanzos/lentejas (escurrido)</span><span>200 g</span></li>
          <li><span>Atún al natural</span><span>80 g</span></li>
          <li><span>Verdura (tomate, pimiento, cebolla)</span><span>al gusto</span></li>
          <li><span>Queso feta</span><span>20 g</span></li>
          <li><span>Aceite de oliva + vinagre</span><span>1 cuch. café</span></li>
        </ul>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🥚 E — ½ tortilla de patatas</h3>
        <span class="meal-meta">~375 kcal · ~19 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Patata al microondas (haces 500–600 g, comes la mitad)</span><span>~300 g · 210 kcal · 6 g</span></li>
          <li><span>Huevo entero</span><span>1,5 uds · 105 kcal · 9 g</span></li>
          <li><span>Clara de huevo extra</span><span>1 ud · 17 kcal · 3,6 g</span></li>
          <li><span>Aceite en spray</span><span>máx. 1 cuch. café · 45 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Tu forma de hacerla (500–600 g → comes la mitad + claras extra) sale más ligera que la versión genérica. <strong>Bien así.</strong> Solo vigila no pasarte de la mitad cuando quede muy apetecible.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🥣 F — Bowl proteico</h3>
        <span class="meal-meta">~260 kcal · 38 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Yogur griego desnatado</span><span>125 g</span></li>
          <li><span>Whey proteína</span><span>30 g</span></li>
          <li><span>Leche semidesnatada</span><span>100 ml</span></li>
          <li><span>Arándanos / frutos rojos congelados</span><span>80 g</span></li>
        </ul>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🍉 G — Ensalada de sandía (verano)</h3>
        <span class="meal-meta">~380 kcal · ~28 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Sandía</span><span>300 g · 90 kcal</span></li>
          <li><span>Queso feta</span><span>40 g · 107 kcal · 6 g prot</span></li>
          <li><span>Aceitunas negras</span><span>20 g · 52 kcal</span></li>
          <li><span>Atún escurrido</span><span>80 g · 88 kcal · 20 g prot</span></li>
          <li><span>Aceite de oliva (cucharita café) + vinagre + sal</span><span>45 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Cena refrescante de verano. Mucho volumen, proteína decente. Puedes ampliar la sandía libremente si tienes hambre — cada 100 g extra solo son 30 kcal.
        </div>
      </div>
    </div>

      </div>
    </details>

    <div class="callout warning" style="margin-bottom: 10px;">
      <strong>⚠️ Regla del suelo: nunca bajes de 1.700 kcal.</strong> Un déficit mayor de ~700 kcal/día pone al cuerpo en modo alarma — pierde músculo, baja el metabolismo y el rendimiento en el entreno cae. El objetivo es ~2.000 kcal, con un déficit suave de 300–400 kcal respecto al TDEE.
    </div>

    <!-- Snacks colapsable -->
    <details class="recipe-group">
      <summary>🥛 Snack y merienda</summary>
      <div class="recipe-group-body">
        <div class="card" style="margin-bottom:0">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
            <h3 style="margin: 0;">Batido pre-comida</h3>
            <span class="badge badge-accent">120 kcal · 25 g prot</span>
          </div>
          <p style="font-size: 13px; color: var(--muted); margin: 0;">30 g whey + 350 ml agua · 30 min antes de comer si llegas con mucha hambre</p>
        </div>
        <div class="card" style="margin-bottom:0">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
            <h3 style="margin: 0;">Bowl proteico (merienda)</h3>
            <span class="badge badge-green">~220 kcal · 32 g prot</span>
          </div>
          <p style="font-size: 13px; color: var(--muted); margin: 0;">Yogur griego 125 g + 20–30 g whey + frutos rojos + 100 ml leche</p>
        </div>
        <div class="card" style="margin-bottom:0">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
            <h3 style="margin: 0;">Sándwich pavo + queso</h3>
            <span class="badge badge-yellow">~215 kcal · 14 g prot</span>
          </div>
          <p style="font-size: 13px; color: var(--muted); margin: 0;">2 rebanadas pan molde · 4 lonchas pavo · 1 loncha queso tierno</p>
        </div>
        <div class="callout" style="margin: 0;">
          🍉 <strong>Sandía:</strong> 30 kcal/100 g — libre en verano. Fruta en invierno: mandarina (~35 kcal), kiwi (~45 kcal).
        </div>
      </div>
    </details>
  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  ENTRENAMIENTO               ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="entreno">
    <p class="section-title">Entrenamiento</p>

    <!-- Calentamiento -->
    <div class="card" style="margin-bottom: 16px;">
      <h3>🔥 Calentamiento (5 min)</h3>
      <ul class="warmup-list">
        <li><span>Shoulder taps en pike con talones elevados</span><span class="duration">40 s</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Snow reverse angel</span><span class="duration">40 s</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Glute bridge</span><span class="duration">40 s</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Side plank sin tocar rodillas</span><span class="duration">5 reps/lado</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Hollow body hold</span><span class="duration">40 s</span></li>
      </ul>
    </div>

    <!-- Bloque fuerza -->
    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Protocolo de fuerza</p>

    <div class="card" style="margin-bottom: 10px;">
      <h3 style="margin-bottom: 8px;">🎯 Tirón — 10 series · ~50 reps</h3>
      <ul style="list-style: none; padding: 0;">
        <li style="font-size: 13px; color: var(--muted); padding: 5px 0; border-bottom: 1px solid var(--border);"><strong>Pull-ups 5 series:</strong> serie 1 → 1–2 reps antes del fallo · series 2–5 al fallo · 90 s descanso</li>
        <li style="font-size: 13px; color: var(--muted); padding: 5px 0; border-bottom: 1px solid var(--border);"><strong>Pausa 3 min</strong> entre bloques</li>
        <li style="font-size: 13px; color: var(--muted); padding: 5px 0;"><strong>Chin-ups 5 series:</strong> todas al fallo · 90 s descanso</li>
      </ul>
    </div>

    <div class="card" style="margin-bottom: 10px;">
      <h3 style="margin-bottom: 8px;">💥 Empuje — ≥100 reps</h3>
      <ul style="list-style: none; padding: 0;">
        <li style="font-size: 13px; color: var(--muted); padding: 5px 0; border-bottom: 1px solid var(--border);"><strong>Pushups:</strong> mínimo 34+20+20 · ampliar hasta 100 · 60 s descanso</li>
        <li style="font-size: 13px; color: var(--muted); padding: 5px 0;"><strong>Pike pushups 5×5</strong> siempre al final · 90 s descanso</li>
      </ul>
    </div>

    <!-- Escaleras -->
    <div class="callout" style="margin-bottom: 20px;">
      🏠 <strong>Escaleras todos los días:</strong> 2–3 veces/día en 4º piso = ~80–100 kcal extra sin esfuerzo.
    </div>

    <!-- Plan semanal VERANO -->
    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">☀️ Plan semanal — modo verano (sin karate)</p>

    <div class="callout warning" style="margin-bottom: 12px;">
      <strong>4 sesiones/semana en casa:</strong> 2 tirón + 2 empuje · 15–25 min cada una. Meta: 50 reps tirón · ≥100 reps empuje. Bici Z2 aparte mientras estudias.
    </div>

    <style>
      .day-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 10px;
      }
      .day-card:last-child { margin-bottom: 0; }
      .day-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        background: var(--surface2);
      }
      .day-name { font-size: 14px; font-weight: 700; }
      .day-tag {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 99px;
      }
      .tag-hard { background: rgba(108,99,255,.2); color: var(--accent); }
      .tag-medium { background: rgba(67,233,123,.15); color: var(--green); }
      .tag-light { background: rgba(139,146,184,.15); color: var(--muted); }
      .tag-rest { background: rgba(249,199,79,.1); color: var(--yellow); }
      .day-body { padding: 10px 14px; }
      .day-body .block {
        font-size: 13px;
        color: var(--muted);
        padding: 5px 0;
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 8px;
      }
      .day-body .block:last-child { border-bottom: none; }
      .day-body .block .blk-icon { flex-shrink: 0; }
    </style>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Lunes · Jueves</span>
        <span class="day-tag tag-hard">Tirón · 50 reps</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🔥</span><span><strong>Warmup</strong> — 5 min Family Calisthenics</span></div>
        <div class="block"><span class="blk-icon">🎯</span><span><strong>5× pull-ups</strong> — serie 1 sin fallo · 2–5 al fallo · 60–90 s</span></div>
        <div class="block"><span class="blk-icon">⏸️</span><span><strong>Pausa 3 min</strong></span></div>
        <div class="block"><span class="blk-icon">🎯</span><span><strong>5× chin-ups</strong> — todas al fallo · 60–90 s</span></div>
        <div class="block"><span class="blk-icon">⏰</span><span>~20–25 min total · meta ~50 reps</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Martes · Viernes</span>
        <span class="day-tag tag-hard">Empuje · ≥100 reps</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🔥</span><span><strong>Warmup</strong> — 5 min</span></div>
        <div class="block"><span class="blk-icon">💥</span><span><strong>Pushups mínimo</strong> 34+20+20 · ampliar hasta 100 si hay tiempo</span></div>
        <div class="block"><span class="blk-icon">🔺</span><span><strong>Pike pushups</strong> 5×5 siempre al final</span></div>
        <div class="block"><span class="blk-icon">⏱️</span><span>Descanso 60 s pushups · 90 s pike · ~20–25 min</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Miércoles</span>
        <span class="day-tag tag-light">Descanso activo</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🚴</span><span>Bici estática 20–30 min suave (japonés/inglés)</span></div>
        <div class="block"><span class="blk-icon">🏠</span><span>Escaleras 2–3 veces</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Sábado</span>
        <span class="day-tag tag-medium">Parque (opcional)</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🌳</span><span>Australianas + dips — solo si vas al parque</span></div>
        <div class="block"><span class="blk-icon">🍱</span><span>Preparar tuppers del domingo</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Domingo</span>
        <span class="day-tag tag-rest">Descanso completo</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🏠</span><span>Escaleras — lo único del día</span></div>
        <div class="block"><span class="blk-icon">🍱</span><span>Preparar 5 raciones de tupper (40 min) — la semana resuelta</span></div>
        <div class="block"><span class="blk-icon">😴</span><span>Recuperación total</span></div>
      </div>
    </div>

    <!-- Progresión -->
    <p style="font-size: 13px; color: var(--muted); margin: 20px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Progresión</p>

    <div class="card" style="margin-bottom: 10px;">
      <h4>Tirón — últimas sesiones</h4>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Fecha</th><th>Pull-ups</th><th>Chin-ups</th><th>Total</th></tr></thead>
          <tbody>
            {progTiron.map(s => (
              <tr>
                <td>{new Date(s.fecha + 'T12:00:00').toLocaleDateString('es-ES', { day: 'numeric', month: 'short' })}</td>
                <td>{s.pullups ?? '—'}</td>
                <td>{s.chinups ?? '—'}</td>
                <td><strong>{s.pullups != null && s.chinups != null ? s.pullups + s.chinups : (s.pullups ?? s.chinups ?? '—')}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <h4>Empuje — últimas sesiones</h4>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Fecha</th><th>Pushups totales</th></tr></thead>
          <tbody>
            {progEmpuje.map(s => (
              <tr>
                <td>{new Date(s.fecha + 'T12:00:00').toLocaleDateString('es-ES', { day: 'numeric', month: 'short' })}</td>
                <td><strong>{s.pushups ?? '—'}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  SEGUIMIENTO                 ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="seguimiento">
    <p class="section-title">Seguimiento</p>

    <WeeklyChart entries={tracking} tdee={2400} />

    <!-- Diario de tracking -->
    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Diario reciente</p>

    <style>
      .log-day {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 12px 14px;
        margin-bottom: 8px;
      }
      .log-day:last-child { margin-bottom: 0; }
      .log-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
      }
      .log-date { font-size: 12px; color: var(--muted); font-weight: 500; }
      .log-macros { display: flex; gap: 10px; align-items: center; }
      .log-kcal { font-size: 16px; font-weight: 700; }
      .log-prot { font-size: 12px; color: var(--green); font-weight: 600; }
      .log-entreno { font-size: 12px; color: var(--accent); margin-bottom: 4px; }
      .log-nota { font-size: 12px; color: var(--muted); }
    </style>

    {diasRecientes.map((d) => (
      <div class="log-day">
        <div class="log-top">
          <span class="log-date">{new Date(d.fecha + 'T12:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' })}</span>
          <div class="log-macros">
            <span class="log-prot">{d.proteina}g prot</span>
            <span class="log-kcal" style={`color: ${kcalColor(d.kcal)}`}>{d.kcal} kcal</span>
          </div>
        </div>
        {d.entreno && <div class="log-entreno">💪 {d.entreno}</div>}
        <div class="log-nota">{d.notas}</div>
      </div>
    ))}

    {diasAnteriores.length > 0 && (
      <details class="log-more">
        <summary>Ver {diasAnteriores.length} días anteriores</summary>
        {diasAnteriores.map((d) => (
          <div class="log-day">
            <div class="log-top">
              <span class="log-date">{new Date(d.fecha + 'T12:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' })}</span>
              <div class="log-macros">
                <span class="log-prot">{d.proteina}g prot</span>
                <span class="log-kcal" style={`color: ${kcalColor(d.kcal)}`}>{d.kcal} kcal</span>
              </div>
            </div>
            {d.entreno && <div class="log-entreno">💪 {d.entreno}</div>}
            <div class="log-nota">{d.notas}</div>
          </div>
        ))}
      </details>
    )}

    <p style="font-size: 13px; color: var(--muted); margin: 20px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Métricas</p>

    <WeightChart metrics={metricas} />

    {ultimaMetrica && (
      <div class="card" style="margin-bottom: 12px;">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">
              Última medición · {new Date(ultimaMetrica.fecha + 'T12:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' })}
            </div>
            <div style="display: flex; gap: 20px;">
              <span><strong style="font-size: 20px; color: var(--accent);">{ultimaMetrica.peso} kg</strong> <span style="font-size: 12px; color: var(--muted);">peso</span></span>
              <span><strong style="font-size: 20px; color: var(--accent);">{ultimaMetrica.cintura} cm</strong> <span style="font-size: 12px; color: var(--muted);">cintura</span></span>
            </div>
          </div>
        </div>
        {ultimaMetrica.notas && <p style="font-size: 12px; color: var(--muted); margin-top: 8px; margin-bottom: 0;">{ultimaMetrica.notas}</p>}
      </div>
    )}

    <!-- Métricas guía -->
    <div class="metric-grid" style="margin-bottom: 16px;">
      <div class="metric-card">
        <div class="icon">⚖️</div>
        <h4>Peso</h4>
        <div class="freq">Cada lunes</div>
        <p>En ayunas, tras ir al baño</p>
      </div>
      <div class="metric-card">
        <div class="icon">📏</div>
        <h4>Cintura</h4>
        <div class="freq">Cada 2 semanas</div>
        <p>Mañana, zona más ancha</p>
      </div>
      <div class="metric-card">
        <div class="icon">💪</div>
        <h4>Pull-ups</h4>
        <div class="freq">Cada sesión</div>
        <p>Progresión de fuerza real</p>
      </div>
      <div class="metric-card">
        <div class="icon">📸</div>
        <h4>Foto</h4>
        <div class="freq">Mensual</div>
        <p>Mañana, mismo ángulo</p>
      </div>
    </div>

    <div class="callout" style="margin-bottom: 16px;">
      No necesitas app de calorías si sigues el tupper fijo + cenas del plan. Si una semana no baja nada, pásate <strong>3 días registrando</strong> para identificar el fallo concreto.
    </div>

    <!-- Hitos por cintura -->
    <div class="card">
      <h3>Hitos por cintura</h3>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>95 cm · <span style="color: var(--muted); font-size: 13px;">4–6 semanas</span></h4>
          <p>Primera señal real de pérdida de grasa visceral</p>
        </div>
      </div>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>93 cm · <span style="color: var(--muted); font-size: 13px;">8–12 semanas</span></h4>
          <p>Empieza a notarse en ropa y espejo</p>
        </div>
      </div>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>90 cm · <span style="color: var(--muted); font-size: 13px;">16–22 semanas</span></h4>
          <p>Más ligero y ágil en kumite y kata</p>
        </div>
      </div>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>87 cm · <span style="color: var(--muted); font-size: 13px;">largo plazo</span></h4>
          <p>Definición visible sostenida</p>
        </div>
      </div>
    </div>

    <!-- Reglas simples -->
    <div class="card" style="margin-top: 16px;">
      <h3 style="margin-bottom: 12px;">5 reglas cuando no recuerdes nada más</h3>
      <ol class="rules-list">
        <li>Tupper fijo de lunes a viernes. No improvises la comida principal.</li>
        <li>Mide el aceite siempre. Cucharita de café, no cuchara sopera.</li>
        <li>Si el sábado comes fuera: cena E esa noche. Sin negociar.</li>
        <li>Los pull-ups son la prioridad número uno en el entrenamiento.</li>
        <li>La báscula puede subir aunque lo hagas bien. Fíate de la cintura y las fotos.</li>
      </ol>
    </div>


    <p style="font-size: 11px; color: var(--muted); text-align: center; margin-top: 20px; padding-bottom: 8px;">
      Plan generado con Claude · Actualizado julio 2026
    </p>
  </section>

</Layout>
