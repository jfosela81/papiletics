---
import Layout from '../layouts/Layout.astro';
import WeeklyChart from '../components/WeeklyChart.astro';
import tracking from '../content/tracking.json';
import metrics from '../content/metrics.json';
import { sortByDateDesc } from '../utils/weeklyBalance';

const dias = sortByDateDesc(tracking);
const metricas = sortByDateDesc(metrics);
const ultimaMetrica = metricas[0];

function kcalColor(kcal: number) {
  if (kcal < 1700) return 'var(--accent2)';
  if (kcal <= 2100) return 'var(--green)';
  return 'var(--yellow)';
}
---
<Layout title="Papiletics — Plan de recomposición corporal">

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  PERFIL                      ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="perfil">
    <p class="section-title">Perfil</p>

    <div class="stats">
      <div class="stat">
        <div class="val">85,9 kg</div>
        <div class="lbl">Peso actual</div>
      </div>
      <div class="stat">
        <div class="val">80 kg</div>
        <div class="lbl">Objetivo</div>
      </div>
      <div class="stat">
        <div class="val">99 cm</div>
        <div class="lbl">Cintura actual</div>
      </div>
      <div class="stat">
        <div class="val">25,1</div>
        <div class="lbl">IMC (kg/m²)</div>
      </div>
    </div>

    <div class="card">
      <h4>Cálculos base</h4>
      <div class="table-wrap">
        <table>
          <tbody>
            <tr><td>Edad / Altura</td><td><strong>45 años · 1.85 m</strong></td></tr>
            <tr><td>BMR estimado (Mifflin-St Jeor)</td><td><strong>~1.796 kcal</strong></td></tr>
            <tr><td>TDEE (actividad ligera-moderada)</td><td><strong>~2.400 kcal</strong></td></tr>
            <tr><td>Objetivo calórico diario</td><td><strong>~2.000 kcal</strong></td></tr>
            <tr><td>Déficit real estimado</td><td><strong>~400 kcal/día</strong></td></tr>
            <tr><td>Proteína diaria objetivo</td><td><strong>160–175 g (2 g/kg)</strong></td></tr>
            <tr><td>Tiempo estimado al objetivo</td><td><strong>20–28 semanas</strong></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="callout">
      <strong>Pérdida esperada:</strong> 0.5–1 kg de grasa/mes si el déficit es consistente. La cintura es mejor indicador que el peso a corto plazo.
    </div>

    <div class="card">
      <h4>Lo que ya tienes correcto</h4>
      <ul style="list-style: none; padding: 0;">
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">✅ <strong>IF 16/8 natural</strong> — no rompas lo que funciona</li>
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">✅ <strong>Sin alcohol ni refrescos</strong> — ventaja de ~300–500 kcal/día</li>
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">✅ <strong>Déficit ligero</strong> — protege el músculo y el metabolismo</li>
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">✅ <strong>Base de proteína alta</strong> — pollo, atún, huevo, whey, yogur griego</li>
        <li style="padding: 7px 0; font-size: 13px; color: var(--muted);">✅ <strong>Fuerza + HIIT + karate</strong> — más inteligente que solo cardio</li>
      </ul>
    </div>

    <div class="card">
      <h4>Suplementación</h4>
      <ul style="list-style: none; padding: 0;">
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">💊 <strong>Creatina:</strong> 3–5 g/día en ayunas. Correcto.</li>
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🥛 <strong>Whey:</strong> 20–30 g post-entreno o como snack. Bien integrada.</li>
        <li style="padding: 7px 0; font-size: 13px; color: var(--muted);">🚫 <strong>Nada más necesario</strong> a este nivel de actividad.</li>
      </ul>
    </div>
  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  NUTRICIÓN                   ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="nutricion">
    <p class="section-title">Nutrición</p>

    <!-- Presupuesto calórico -->
    <div class="card" style="margin-bottom: 16px;">
      <h3>Presupuesto calórico diario</h3>
      <div class="budget-item">
        <span class="budget-label">Comida (tupper)</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 32%"></div></div>
        <span class="budget-kcal">640 kcal</span>
      </div>
      <div class="budget-item">
        <span class="budget-label">Cena</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 24%; background: var(--green)"></div></div>
        <span class="budget-kcal">480 kcal</span>
      </div>
      <div class="budget-item">
        <span class="budget-label">Snack proteico</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 12%; background: var(--yellow)"></div></div>
        <span class="budget-kcal">240 kcal</span>
      </div>
      <div class="budget-item">
        <span class="budget-label">Margen errores</span>
        <div class="budget-bar"><div class="budget-bar-fill" style="width: 32%; background: var(--border)"></div></div>
        <span class="budget-kcal">640 kcal</span>
      </div>
      <div style="border-top: 1px solid var(--border); margin-top: 12px; padding-top: 10px; display: flex; justify-content: space-between; align-items: center;">
        <span style="font-size: 13px; color: var(--muted);">TOTAL DIARIO</span>
        <span style="font-size: 20px; font-weight: 700; color: var(--accent);">~2.000 kcal</span>
      </div>
    </div>

    <!-- Tupper fijo -->
    <div class="meal-card">
      <div class="meal-header">
        <h3>🍱 Tupper fijo (L–V)</h3>
        <span class="meal-meta">~600 kcal · ~49 g prot</span>
      </div>
      <div class="meal-body">
        <h4>Pollo con pisto y quinoa</h4>
        <ul>
          <li><span>Pechuga de pollo (crudo)</span><span>200 g · 220 kcal · 42 g</span></li>
          <li><span>Cebolla + pimiento + calabacín</span><span>150 g · 60 kcal</span></li>
          <li><span>Tomate triturado</span><span>150 ml · 40 kcal</span></li>
          <li><span>Quinoa en seco (o arroz blanco)</span><span>65 g · 235 kcal · 7 g</span></li>
          <li><span>Aceite de oliva (cucharita de café)</span><span>5 ml · 45 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 12px; margin-bottom: 0;">
          <strong>Logística:</strong> Prepara 5 raciones el domingo. Refrigera 3, congela 2. En 40 minutos tienes la semana resuelta. Los martes cuando preparas el caldo de tus hijas es buen momento.
        </div>
      </div>
    </div>

    <!-- Cenas -->
    <p style="font-size: 13px; color: var(--muted); margin: 16px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Cenas rotativas (elige una)</p>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🥗 A — Lechuga + atún + huevo + salsa fit</h3>
        <span class="meal-meta">~490 kcal · 50 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Lechuga iceberg</span><span>150–160 g</span></li>
          <li><span>Atún (girasol o natural)</span><span>100 g</span></li>
          <li><span>Huevo duro</span><span>1 ud</span></li>
          <li><span>Pan de molde</span><span>65–70 g (2 rebanadas)</span></li>
          <li><span>Salsa: yogur griego 100 g + mostaza 20 g + mayo ligera 15 g + limón + ajo + sal</span><span>~120 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          La cena más repetida y más completa. Pan real, sin trucos raros. Si el atún es en girasol, escurre bien.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🫓 B — Pizza tortilla de trigo integral (verano)</h3>
        <span class="meal-meta">~500–550 kcal · 38–42 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Tortilla de trigo integral (~45 g)</span><span>~145 kcal</span></li>
          <li><span>Tomate triturado natural</span><span>80–100 g · ~30 kcal</span></li>
          <li><span>Mozzarella</span><span>80 g · ~220 kcal · 16 g prot</span></li>
          <li><span>Pollo en tiras o atún</span><span>100 g · ~110–90 kcal · ~22 g prot</span></li>
          <li><span>Pimiento + cebolla + champiñones (salteados)</span><span>libres · ~30 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Sartén a fuego medio tapada — efecto horno. Mozzarella máx. 80 g. Sin bases de coliflor ni garbanzos — la tortilla integral ya es la solución correcta.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🐟 C — Salmón + brócoli</h3>
        <span class="meal-meta">~310 kcal · 32 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Salmón a la plancha</span><span>150 g</span></li>
          <li><span>Brócoli al vapor / plancha</span><span>200 g</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Solo si sobra salmón de la comida — no planificar como cena fija.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🫘 D — Ensalada de legumbres</h3>
        <span class="meal-meta">~460 kcal · 32 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Garbanzos/lentejas (escurrido)</span><span>200 g</span></li>
          <li><span>Atún al natural</span><span>80 g</span></li>
          <li><span>Verdura (tomate, pimiento, cebolla)</span><span>al gusto</span></li>
          <li><span>Queso feta</span><span>20 g</span></li>
          <li><span>Aceite de oliva + vinagre</span><span>1 cuch. café</span></li>
        </ul>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🥚 E — ½ tortilla de patatas</h3>
        <span class="meal-meta">~375 kcal · ~19 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Patata al microondas (haces 500–600 g, comes la mitad)</span><span>~300 g · 210 kcal · 6 g</span></li>
          <li><span>Huevo entero</span><span>1,5 uds · 105 kcal · 9 g</span></li>
          <li><span>Clara de huevo extra</span><span>1 ud · 17 kcal · 3,6 g</span></li>
          <li><span>Aceite en spray</span><span>máx. 1 cuch. café · 45 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Tu forma de hacerla (500–600 g → comes la mitad + claras extra) sale más ligera que la versión genérica. <strong>Bien así.</strong> Solo vigila no pasarte de la mitad cuando quede muy apetecible.
        </div>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🥣 F — Bowl proteico</h3>
        <span class="meal-meta">~260 kcal · 38 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Yogur griego desnatado</span><span>125 g</span></li>
          <li><span>Whey proteína</span><span>30 g</span></li>
          <li><span>Leche semidesnatada</span><span>100 ml</span></li>
          <li><span>Arándanos / frutos rojos congelados</span><span>80 g</span></li>
        </ul>
      </div>
    </div>

    <div class="meal-card">
      <div class="meal-header">
        <h3>🍉 G — Ensalada de sandía (verano)</h3>
        <span class="meal-meta">~380 kcal · ~28 g prot</span>
      </div>
      <div class="meal-body">
        <ul>
          <li><span>Sandía</span><span>300 g · 90 kcal</span></li>
          <li><span>Queso feta</span><span>40 g · 107 kcal · 6 g prot</span></li>
          <li><span>Aceitunas negras</span><span>20 g · 52 kcal</span></li>
          <li><span>Atún escurrido</span><span>80 g · 88 kcal · 20 g prot</span></li>
          <li><span>Aceite de oliva (cucharita café) + vinagre + sal</span><span>45 kcal</span></li>
        </ul>
        <div class="callout" style="margin-top: 10px; margin-bottom: 0;">
          Cena refrescante de verano. Mucho volumen, proteína decente. Puedes ampliar la sandía libremente si tienes hambre — cada 100 g extra solo son 30 kcal.
        </div>
      </div>
    </div>

    <div class="callout warning" style="margin-bottom: 10px;">
      <strong>⚠️ Regla del suelo: nunca bajes de 1.700 kcal.</strong> Un déficit mayor de ~700 kcal/día pone al cuerpo en modo alarma — pierde músculo, baja el metabolismo y el rendimiento en el entreno cae. El objetivo es ~2.000 kcal, con un déficit suave de 300–400 kcal respecto al TDEE.
    </div>

    <div class="card" style="margin-bottom: 16px;">
      <h4>Cómo llegar a 2.000 kcal en noches de cena ligera</h4>
      <p style="font-size: 13px; color: var(--muted); margin-bottom: 10px;">Con tupper (600) + cena B o E (260–310) + snacks (340) solo llegas a ~1.300 kcal. Rellena el hueco así:</p>
      <ul style="list-style: none; padding: 0;">
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🍉 <strong>Sandía post-comida (verano):</strong> 400–500 g = 120–150 kcal. Coste casi nulo.</li>
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🥛 <strong>Yogur griego solo (noche):</strong> 125 g desnatado = 70 kcal · o 125 g 2% = 90 kcal.</li>
        <li style="padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🍞 <strong>2 tostadas con pavo y queso tierno:</strong> pan integral + 2 lonchas pavo + 1 loncha queso tierno (~20 g) → ~215 kcal · 14 g prot. Saciante y dentro del plan.</li>
        <li style="padding: 7px 0; font-size: 13px; color: var(--muted);">🧀 <strong>30 g queso en bolsita (ya porcionado):</strong> 120 kcal. Solo si no has picado de más antes.</li>
      </ul>
      <p style="font-size: 12px; color: var(--green); margin-top: 10px; margin-bottom: 0;">Con sandía + yogur de noche ya sumas ~200–240 kcal extra → total del día ~1.550–1.600 kcal. Con el aceite real (no en spray) y algún mordisco más llegas cómodamente a 1.700–1.800 kcal. <strong>Eso sí es un déficit suave.</strong></p>
    </div>

    <!-- Fruta de verano -->
    <div class="callout" style="margin-bottom: 16px;">
      🍉 <strong>Sandía en verano:</strong> 30 kcal/100 g — la fruta más eficiente. Puedes comer 400–500 g después de comer y solo sumas 120–150 kcal. En invierno: mandarina (~35 kcal), kiwi (~45 kcal), melocotón (~45 kcal).
    </div>

    <!-- Snacks -->
    <p style="font-size: 13px; color: var(--muted); margin: 16px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Snack / post-entrenamiento</p>

    <div class="card">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
        <h3 style="margin: 0;">Batido pre-comida (corta el hambre)</h3>
        <span class="badge badge-accent">120 kcal · 25 g prot</span>
      </div>
      <p style="font-size: 13px; color: var(--muted); margin: 0;">30 g whey + 350 ml agua · 30 min antes de comer si llegas con mucha hambre</p>
    </div>

    <div class="card">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
        <h3 style="margin: 0;">Bowl proteico por la tarde (si tienes hambre)</h3>
        <span class="badge badge-green">~220 kcal · 32 g prot</span>
      </div>
      <p style="font-size: 13px; color: var(--muted); margin: 0;">Yogur griego 125 g + 20 g whey + frutos rojos + 100 ml leche</p>
      <p style="font-size: 12px; color: var(--yellow); margin-top: 6px; margin-bottom: 0;">Si tomas el batido pre-comida <strong>y</strong> el bowl de tarde (~340 kcal total), la tarde está cerrada — sin picar más.</p>
    </div>

    <!-- Fruta -->
    <div class="callout">
      🍊 <strong>Fruta:</strong> 2 piezas/día está perfecto (mandarina, kiwi, melocotón, sandía en verano) — ~100 kcal. No hay que eliminarla.
    </div>

    <!-- Fines de semana -->
    <p style="font-size: 13px; color: var(--muted); margin: 16px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Fines de semana</p>

    <div class="card">
      <ul style="list-style: none; padding: 0;">
        <li style="padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🍽️ <strong>Si comes fuera en restaurante:</strong> cena B o E esa noche, sin negociar.</li>
        <li style="padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🥘 <strong>Paella del sábado</strong> (100 g arroz para dos): bien. No toques esa receta.</li>
        <li style="padding: 8px 0; font-size: 13px; color: var(--muted);">🍔 <strong>Domingos fuera / burger:</strong> 1 burger con queso + salsa yogur. Está dentro del plan.</li>
      </ul>
    </div>

    <p style="font-size: 13px; color: var(--muted); margin: 16px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Casa familiar (madre / suegra)</p>

    <div class="card">
      <p style="font-size: 13px; color: var(--muted); margin-bottom: 10px;">No controlas ingredientes ni cantidades — no lo intentes. No es el momento ni el lugar. Lo que sí controlas es lo que haces antes y después.</p>
      <ul style="list-style: none; padding: 0;">
        <li style="padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">🌙 <strong>Por la noche, si llegas sin hambre:</strong> batido whey + agua antes de dormir. 120 kcal · 25 g proteína. Sin cenar nada más — no hace falta.</li>
        <li style="padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted);">💪 <strong>Por qué el batido y no nada:</strong> el músculo no recibe proteína durante el ayuno nocturno. 25 g de whey lo evitan sin añadir volumen de comida.</li>
        <li style="padding: 8px 0; font-size: 13px; color: var(--muted);">📅 <strong>El domingo:</strong> vuelta al tupper y a la estructura. La semana no la rompe un sábado en casa familiar — la rompe no recuperar el ritmo el lunes.</li>
      </ul>
    </div>
  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  ENTRENAMIENTO               ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="entreno">
    <p class="section-title">Entrenamiento</p>

    <!-- Estado actual -->
    <div class="card" style="margin-bottom: 16px;">
      <h4>Estado actual</h4>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Capacidad</th><th>Nivel</th></tr>
          </thead>
          <tbody>
            <tr><td>Empuje (push)</td><td><span class="badge badge-green">Muy bueno</span></td></tr>
            <tr><td>Tirón (pull)</td><td><span class="badge badge-red">Déficit</span></td></tr>
            <tr><td>Piernas / Core</td><td><span class="badge badge-yellow">Suficiente</span></td></tr>
            <tr><td>Cardio</td><td><span class="badge badge-yellow">Suficiente</span></td></tr>
          </tbody>
        </table>
      </div>
      <div class="callout danger" style="margin-top: 12px; margin-bottom: 0;">
        <strong>⚠️ Problema principal:</strong> desequilibrio push/pull. Los pull-ups que planeas añadir son exactamente la corrección correcta. Sin trabajo de tracción, el hombro se resiente a largo plazo — especialmente crítico para karate.
      </div>
    </div>

    <!-- Calentamiento -->
    <div class="card" style="margin-bottom: 16px;">
      <h3>🔥 Calentamiento (5 min)</h3>
      <ul class="warmup-list">
        <li><span>Shoulder taps en pike con talones elevados</span><span class="duration">40 s</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Snow reverse angel</span><span class="duration">40 s</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Glute bridge</span><span class="duration">40 s</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Side plank sin tocar rodillas</span><span class="duration">5 reps/lado</span></li>
        <li><span>Descanso</span><span class="duration">20 s</span></li>
        <li><span>Hollow body hold</span><span class="duration">40 s</span></li>
      </ul>
    </div>

    <!-- Bloque fuerza -->
    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Bloque de fuerza</p>

    <div class="exercise-card">
      <h3>🎯 Tirón en casa (barra alta) — 10 series · meta ~50 reps</h3>
      <ul>
        <li><strong>Bloque 1 — Pull-ups (5 series):</strong> serie 1 para 1–2 reps antes del fallo (ej. 8 si puedes 10) · series 2–5 al fallo · descanso 60–90 s</li>
        <li><strong>Pausa 3 min</strong> entre bloques — cambio de agarre, tendones listos</li>
        <li><strong>Bloque 2 — Chin-ups (5 series):</strong> todas al fallo · descanso 60–90 s</li>
        <li>Patrón típico pull: 8-7-6-5-5 ≈ 31 reps + chin ≈ 20–25 = <strong>~50–55 reps</strong></li>
        <li>Australianas solo en parque — bonus, no sustituto en casa</li>
      </ul>
    </div>

    <div class="exercise-card">
      <h3>💥 Empuje en casa — meta ≥100 reps/sesión (push + pike)</h3>
      <ul>
        <li><strong>Mínimo:</strong> pushups 34+20+20 (74) + pike pushups 5×5 (25) = 99 reps</li>
        <li><strong>Si hay tiempo:</strong> hasta 100 pushups + 5×5 pike pushups</li>
        <li>Descanso 60 s entre series de pushups · 90 s en pike pushups</li>
        <li>Calidad en pike: profundidad controlada, no contar reps sucias</li>
      </ul>
    </div>

    <div class="exercise-card">
      <h3>⚡ Circuito HIIT (45 s cada uno)</h3>
      <ul>
        <li>Jumping jacks</li>
        <li>Burpee no-jump <em>(objetivo: 15 reps/ronda)</em></li>
        <li>Rodillas a codos en plancha alta</li>
        <li>Rodilla a codo mismo lado en plancha baja</li>
        <li>Patadas de rana sentado</li>
        <li>Elevaciones de rodilla</li>
        <li>Sentadilla + lunge con salto</li>
        <li>In and outs en plancha</li>
      </ul>
    </div>

    <div class="exercise-card">
      <h3>🌳 Parque de calistenia (cuando puedas)</h3>
      <ul>
        <li>Dips en paralelas — complemento al push</li>
        <li>Dominadas australianas — tirón horizontal</li>
        <li>Pino en pared 30 s — hombros y propiocepción</li>
        <li>Muscle-up negatives — objetivo a medio plazo</li>
      </ul>
    </div>

    <!-- Escaleras -->
    <div class="callout" style="margin-bottom: 20px;">
      🏠 <strong>Escaleras todos los días:</strong> 2–3 veces/día en 4º piso = ~80–100 kcal extra sin esfuerzo.
    </div>

    <!-- Plan semanal VERANO -->
    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">☀️ Plan semanal — modo verano (sin karate)</p>

    <div class="callout warning" style="margin-bottom: 12px;">
      <strong>4 sesiones/semana en casa:</strong> 2 tirón + 2 empuje · 15–25 min cada una. Meta: 50 reps tirón · ≥100 reps empuje (push + pike). HIIT opcional. Bici Z2 aparte mientras estudias.
    </div>

    <style>
      .day-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 10px;
      }
      .day-card:last-child { margin-bottom: 0; }
      .day-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        background: var(--surface2);
      }
      .day-name { font-size: 14px; font-weight: 700; }
      .day-tag {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 99px;
      }
      .tag-hard { background: rgba(108,99,255,.2); color: var(--accent); }
      .tag-medium { background: rgba(67,233,123,.15); color: var(--green); }
      .tag-light { background: rgba(139,146,184,.15); color: var(--muted); }
      .tag-rest { background: rgba(249,199,79,.1); color: var(--yellow); }
      .day-body { padding: 10px 14px; }
      .day-body .block {
        font-size: 13px;
        color: var(--muted);
        padding: 5px 0;
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 8px;
      }
      .day-body .block:last-child { border-bottom: none; }
      .day-body .block .blk-icon { flex-shrink: 0; }
    </style>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Lunes · Jueves</span>
        <span class="day-tag tag-hard">Tirón · 50 reps</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🔥</span><span><strong>Warmup</strong> — 5 min Family Calisthenics</span></div>
        <div class="block"><span class="blk-icon">🎯</span><span><strong>5× pull-ups</strong> — serie 1 sin fallo · 2–5 al fallo · 60–90 s</span></div>
        <div class="block"><span class="blk-icon">⏸️</span><span><strong>Pausa 3 min</strong></span></div>
        <div class="block"><span class="blk-icon">🎯</span><span><strong>5× chin-ups</strong> — todas al fallo · 60–90 s</span></div>
        <div class="block"><span class="blk-icon">⏰</span><span>~20–25 min total · meta ~50 reps</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Martes · Viernes</span>
        <span class="day-tag tag-hard">Empuje · ≥100 reps</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🔥</span><span><strong>Warmup</strong> — 5 min</span></div>
        <div class="block"><span class="blk-icon">💥</span><span><strong>Pushups mínimo</strong> 34+20+20 · ampliar hasta 100 si hay tiempo</span></div>
        <div class="block"><span class="blk-icon">🔺</span><span><strong>Pike pushups</strong> 5×5 siempre al final</span></div>
        <div class="block"><span class="blk-icon">⏱️</span><span>Descanso 60 s pushups · 90 s pike · ~20–25 min</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Miércoles</span>
        <span class="day-tag tag-light">Descanso activo</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🚴</span><span>Bici estática 20–30 min suave (japonés/inglés)</span></div>
        <div class="block"><span class="blk-icon">🏠</span><span>Escaleras 2–3 veces</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Sábado</span>
        <span class="day-tag tag-medium">Parque (opcional)</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🌳</span><span>Australianas + dips — solo si vas al parque</span></div>
        <div class="block"><span class="blk-icon">🍱</span><span>Preparar tuppers del domingo</span></div>
      </div>
    </div>

    <div class="day-card">
      <div class="day-header">
        <span class="day-name">Domingo</span>
        <span class="day-tag tag-rest">Descanso completo</span>
      </div>
      <div class="day-body">
        <div class="block"><span class="blk-icon">🏠</span><span>Escaleras — lo único del día</span></div>
        <div class="block"><span class="blk-icon">🍱</span><span>Preparar 5 raciones de tupper (40 min) — la semana resuelta</span></div>
        <div class="block"><span class="blk-icon">😴</span><span>Recuperación total</span></div>
      </div>
    </div>

    <div class="callout" style="margin-top: 12px;">
      <strong>HIIT:</strong> resérvalo solo si quieres empujar capacidad aeróbica (pre-karate). Para recomposición, el déficit + proteína + fuerza al fallo es suficiente. Descansos de 60 s no impiden mantener músculo en déficit — la hipertrofia no es el objetivo ahora.
    </div>
  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  SABOTEADORES                ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="saboteadores">
    <p class="section-title">Saboteadores</p>

    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Los que ya conocías</p>

    <div class="saboteador">
      <h3>🍗 Picar mientras cocinas</h3>
      <p class="damage">⚡ 100–300 kcal los días que cocinas</p>
      <p class="fix">Ten pepino/zanahoria en rodajas delante. O chicle sin azúcar. Si llegas con hambre, tómate el batido 30 min antes de cocinar.</p>
    </div>

    <div class="saboteador">
      <h3>😤 Llegar con hambre al mediodía (efecto ayuno)</h3>
      <p class="damage">⚡ El hambre extrema lleva a raciones más grandes y a repetir</p>
      <p class="fix">Batido de whey 30 min antes si sabes que vas a cocinar con hambre. Corta el hambre sin romper el déficit.</p>
    </div>

    <div class="saboteador">
      <h3>📅 Fines de semana sin estructura</h3>
      <p class="damage">⚡ Pueden anular el déficit de 3–4 días de semana</p>
      <p class="fix">Regla fija (ver sección Nutrición). No restricción, solo compensación automática.</p>
    </div>

    <div class="saboteador">
      <h3>🧀 Queso curado</h3>
      <p class="damage">⚡ 30 g = ~120 kcal. Fácil de picar sin darse cuenta</p>
      <p class="fix">Si entra en casa, porciónalo en bolsitas de 30 g el mismo día que lo abres.</p>
    </div>

    <p style="font-size: 13px; color: var(--muted); margin: 20px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Los que probablemente no calculabas</p>

    <div class="saboteador">
      <h3>🫒 Aceite de oliva sin medir ⚠️</h3>
      <p class="damage">⚡ 1 cuchara sopera = 120 kcal. Si entra en 2–3 momentos del día sin medir → 300–400 kcal invisibles</p>
      <p class="fix">Usa spray de aceite para cocinar. Sin spray → mide con cucharita de café (5 ml = 45 kcal).</p>
    </div>

    <div class="saboteador">
      <h3>🍲 3 platos de lentejas "sin chorizo"</h3>
      <p class="damage">⚡ 1 plato = ~260 kcal · Tres platos = ~780 kcal solo de legumbre</p>
      <p class="fix">Máximo 2 platos. El segundo, más pequeño que el primero.</p>
    </div>

    <div class="saboteador">
      <h3>🍳 Porciones de tortilla sin pesarla</h3>
      <p class="damage">⚡ 150 g = ~250 kcal · Una porción "generosa" de 250 g = ~420 kcal</p>
      <p class="fix">Cuando la prepares, córtala en 4–5 porciones iguales y guarda las que no son para esa noche.</p>
    </div>

    <div class="saboteador">
      <h3>🧀 Picar mozzarella montando la lasaña</h3>
      <p class="damage">⚡ 30–50 g = ~100–150 kcal. Suma silenciosamente</p>
      <p class="fix">Pesa los 200 g y ponlos directamente sobre la fuente antes de empezar a montar.</p>
    </div>
  </section>

  <!-- ╔══════════════════════════════╗ -->
  <!-- ║  SEGUIMIENTO                 ║ -->
  <!-- ╚══════════════════════════════╝ -->
  <section class="section" id="seguimiento">
    <p class="section-title">Seguimiento</p>

    <WeeklyChart entries={tracking} tdee={2400} />

    <!-- Diario de tracking -->
    <p style="font-size: 13px; color: var(--muted); margin: 0 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Diario reciente</p>

    <style>
      .log-day {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 12px 14px;
        margin-bottom: 8px;
      }
      .log-day:last-child { margin-bottom: 0; }
      .log-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
      }
      .log-date { font-size: 12px; color: var(--muted); font-weight: 500; }
      .log-macros { display: flex; gap: 10px; align-items: center; }
      .log-kcal { font-size: 16px; font-weight: 700; }
      .log-prot { font-size: 12px; color: var(--green); font-weight: 600; }
      .log-entreno { font-size: 12px; color: var(--accent); margin-bottom: 4px; }
      .log-nota { font-size: 12px; color: var(--muted); }
    </style>

    {dias.map((d) => (
      <div class="log-day">
        <div class="log-top">
          <span class="log-date">{new Date(d.fecha + 'T12:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' })}</span>
          <div class="log-macros">
            <span class="log-prot">{d.proteina}g prot</span>
            <span class="log-kcal" style={`color: ${kcalColor(d.kcal)}`}>{d.kcal} kcal</span>
          </div>
        </div>
        {d.entreno && <div class="log-entreno">💪 {d.entreno}</div>}
        <div class="log-nota">{d.notas}</div>
      </div>
    ))}

    <p style="font-size: 13px; color: var(--muted); margin: 20px 0 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;">Métricas</p>

    {ultimaMetrica && (
      <div class="card" style="margin-bottom: 12px;">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">
              Última medición · {new Date(ultimaMetrica.fecha + 'T12:00:00').toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short' })}
            </div>
            <div style="display: flex; gap: 20px;">
              <span><strong style="font-size: 20px; color: var(--accent);">{ultimaMetrica.peso} kg</strong> <span style="font-size: 12px; color: var(--muted);">peso</span></span>
              <span><strong style="font-size: 20px; color: var(--accent);">{ultimaMetrica.cintura} cm</strong> <span style="font-size: 12px; color: var(--muted);">cintura</span></span>
            </div>
          </div>
        </div>
        {ultimaMetrica.notas && <p style="font-size: 12px; color: var(--muted); margin-top: 8px; margin-bottom: 0;">{ultimaMetrica.notas}</p>}
      </div>
    )}

    <!-- Métricas guía -->
    <div class="metric-grid" style="margin-bottom: 16px;">
      <div class="metric-card">
        <div class="icon">⚖️</div>
        <h4>Peso</h4>
        <div class="freq">Cada lunes</div>
        <p>En ayunas, tras ir al baño</p>
      </div>
      <div class="metric-card">
        <div class="icon">📏</div>
        <h4>Cintura</h4>
        <div class="freq">Cada 2 semanas</div>
        <p>Mañana, zona más ancha</p>
      </div>
      <div class="metric-card">
        <div class="icon">💪</div>
        <h4>Pull-ups</h4>
        <div class="freq">Cada sesión</div>
        <p>Progresión de fuerza real</p>
      </div>
      <div class="metric-card">
        <div class="icon">📸</div>
        <h4>Foto</h4>
        <div class="freq">Mensual</div>
        <p>Mañana, mismo ángulo</p>
      </div>
    </div>

    <div class="callout" style="margin-bottom: 16px;">
      No necesitas app de calorías si sigues el tupper fijo + cenas del plan. Si una semana no baja nada, pásate <strong>3 días registrando</strong> para identificar el fallo concreto.
    </div>

    <!-- Hitos por cintura -->
    <div class="card">
      <h3>Hitos por cintura</h3>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>95 cm · <span style="color: var(--muted); font-size: 13px;">4–6 semanas</span></h4>
          <p>Primera señal real de pérdida de grasa visceral</p>
        </div>
      </div>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>93 cm · <span style="color: var(--muted); font-size: 13px;">8–12 semanas</span></h4>
          <p>Empieza a notarse en ropa y espejo</p>
        </div>
      </div>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>90 cm · <span style="color: var(--muted); font-size: 13px;">16–22 semanas</span></h4>
          <p>Más ligero y ágil en kumite y kata</p>
        </div>
      </div>
      <div class="milestone">
        <div class="milestone-dot"></div>
        <div>
          <h4>87 cm · <span style="color: var(--muted); font-size: 13px;">largo plazo</span></h4>
          <p>Definición visible sostenida</p>
        </div>
      </div>
    </div>

    <!-- Reglas simples -->
    <div class="card" style="margin-top: 16px;">
      <h3 style="margin-bottom: 12px;">5 reglas cuando no recuerdes nada más</h3>
      <ol class="rules-list">
        <li>Tupper fijo de lunes a viernes. No improvises la comida principal.</li>
        <li>Mide el aceite siempre. Cucharita de café, no cuchara sopera.</li>
        <li>Si el sábado comes fuera: cena E esa noche. Sin negociar.</li>
        <li>Los pull-ups son la prioridad número uno en el entrenamiento.</li>
        <li>La báscula puede subir aunque lo hagas bien. Fíate de la cintura y las fotos.</li>
      </ol>
    </div>


    <p style="font-size: 11px; color: var(--muted); text-align: center; margin-top: 20px; padding-bottom: 8px;">
      Plan generado con Claude · Actualizado julio 2026
    </p>
  </section>

</Layout>
